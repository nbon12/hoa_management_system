@page "/dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Dashboard - HOA Management</PageTitle>

<h1>Dashboard</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5>Welcome, @authContext.User.Identity?.Name!</h5>
                    </div>
                    <div class="card-body">
                        <p>This is a protected dashboard page that requires authentication.</p>
                        <p>You can only see this content because you are logged in.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5>Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <a href="/violations" class="btn btn-primary me-2">View Violations</a>
                        <a href="/violation-types" class="btn btn-secondary">Manage Violation Types</a>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="mt-4">
            <h3>User Information</h3>
            <p><strong>Username:</strong> @authContext.User.Identity?.Name</p>
            <p><strong>Authentication Type:</strong> @authContext.User.Identity?.AuthenticationType</p>
            <p><strong>Is Authenticated:</strong> @authContext.User.Identity?.IsAuthenticated</p>
        </div>
    </Authorized>
</AuthorizeView> 