@page "/user-roles"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using HOAManagementCompany.Services
@using HOAManagementCompany.Constants
@inject UserRoleService UserRoleService
@inject IJSRuntime JsRuntime

<PageTitle>User Role Management - HOA Management</PageTitle>

<h1>User Role Management</h1>
<p class="text-muted">Manage user roles and permissions. Only administrators can access this page.</p>

@if (users == null || roles == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Users and Their Roles</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Current Roles</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td>@user.UserName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @if (userRoles.ContainsKey(user.Id) && userRoles[user.Id].Any())
                                        {
                                            @foreach (var role in userRoles[user.Id])
                                            {
                                                <span class="badge bg-primary me-1">@role</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No roles assigned</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => OpenRoleModal(user.Id, user.UserName ?? ""))">
                                            Manage Roles
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<!-- Role Management Modal -->
@if (showModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Roles for @selectedUserName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (selectedUserRoles != null)
                    {
                        <div class="mb-3">
                            <h6>Available Roles:</h6>
                            @if (roles != null)
                            {
                                @foreach (var role in roles)
                                {
                                    var isInRole = selectedUserRoles?.Contains(role.Name ?? "") ?? false;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" 
                                               id="role_@role.Id" 
                                               checked="@isInRole"
                                               @onchange="@(async (e) => await ToggleRole(role.Name ?? "", e.Value))" />
                                        <label class="form-check-label" for="role_@role.Id">
                                            @role.Name
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<IdentityUser>? users;
    private List<IdentityRole>? roles;
    private Dictionary<string, List<string>> userRoles = new();
    private bool showModal = false;
    private string? selectedUserId;
    private string? selectedUserName;
    private List<string>? selectedUserRoles;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            users = await UserRoleService.GetAllUsersAsync();
            roles = await UserRoleService.GetAllRolesAsync();
            
            // Load all user roles
            userRoles.Clear();
            foreach (var user in users)
            {
                userRoles[user.Id] = await UserRoleService.GetUserRolesAsync(user.Id);
            }
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("alert", $"Error loading data: {ex.Message}");
        }
    }

    private async Task OpenRoleModal(string userId, string userName)
    {
        selectedUserId = userId;
        selectedUserName = userName;
        selectedUserRoles = await UserRoleService.GetUserRolesAsync(userId);
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        selectedUserId = null;
        selectedUserName = null;
        selectedUserRoles = null;
        StateHasChanged();
    }

    private async Task ToggleRole(string roleName, object? isChecked)
    {
        if (selectedUserId == null) return;

        bool shouldAdd = isChecked as bool? ?? false;
        
        try
        {
            bool success;
            if (shouldAdd)
            {
                success = await UserRoleService.AddUserToRoleAsync(selectedUserId, roleName);
                if (success && selectedUserRoles != null)
                {
                    selectedUserRoles.Add(roleName);
                }
            }
            else
            {
                success = await UserRoleService.RemoveUserFromRoleAsync(selectedUserId, roleName);
                if (success && selectedUserRoles != null)
                {
                    selectedUserRoles.Remove(roleName);
                }
            }

            if (!success)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"Failed to update role: {roleName}");
            }
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("alert", $"Error updating role: {ex.Message}");
        }
    }
} 