@page "/violationtypes/create"
@page "/violationtypes/edit/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using HOAManagementCompany.Models
@using Microsoft.AspNetCore.Authorization
@inject HOAManagementCompany.Services.ViolationService ViolationService
@inject NavigationManager Navigation

<PageTitle>@(IsCreating ? "Create" : "Edit") Violation Type</PageTitle>

<h3>@(IsCreating ? "Create New" : "Edit") Violation Type</h3>

@if (violationType == null && !IsCreating)
{
    <div id="form-loading-canary" class="alert alert-info">
        <i class="fas fa-spinner fa-spin"></i> Loading violation type...
    </div>
}
else
{
<EditForm Model="@violationType" OnValidSubmit="HandleValidSubmit" FormName="violationTypeForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="name" class="form-label">Name</label>
        <InputText id="name" @bind-Value="violationType.Name" class="form-control" />
        <ValidationMessage For="@(() => violationType.Name)" />
    </div>

    <div class="mb-3">
        <label for="covenantText" class="form-label">Covenant Text</label>
        <InputTextArea id="covenantText" @bind-Value="violationType.CovenantText" class="form-control" rows="5" />
        <ValidationMessage For="@(() => violationType.CovenantText)" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <button type="button" class="btn btn-secondary" @onclick="NavigateBack">Cancel</button>
</EditForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; } 

    private ViolationType violationType = new ViolationType
    {
        Name = string.Empty,
        CovenantText = string.Empty
    };
    private bool IsCreating => Id == Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!IsCreating) // If Id is not Guid.Empty, we are in Edit mode
        {
            var existingViolationType = await ViolationService.GetViolationTypeByIdAsync(Id);
            if (existingViolationType != null)
            {
                violationType = existingViolationType;
            }
            else
            {
                Console.WriteLine($"ViolationType with ID {Id} not found.");
                Navigation.NavigateTo("/violationtypes"); // Redirect back to list
            }
        }
        else
        {
            violationType.Id = Guid.NewGuid();
        }
    }

    private async Task HandleValidSubmit()
    {
        if (IsCreating) // Create new
        {
            // If Guid.NewGuid() was not set in OnInitializedAsync for creation,
            // EF Core will assign one when Add() is called and SaveChangesAsync().
            // But if you need it before SaveChanges (e.g., for logging), it's good to set it.
            // Ensure violationType.Id is set to a new GUID before adding if you haven't already.
            if (violationType.Id == Guid.Empty)
            {
                violationType.Id = Guid.NewGuid();
            }
            await ViolationService.AddViolationTypeAsync(violationType);
            Console.WriteLine($"Created new ViolationType: {violationType.Name} with ID: {violationType.Id}");
        }
        else // Update existing
        {
            await ViolationService.UpdateViolationTypeAsync(violationType);
            Console.WriteLine($"Updated ViolationType: {violationType.Id} - {violationType.Name}");
        }

    // Navigate back to the list page after save
        Navigation.NavigateTo("/violationtypes");
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/violationtypes");
    }
}