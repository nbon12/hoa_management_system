# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 sandbox integration tests (007) — local provider credentials
#
# 1. Copy this file to `.env`  (already git-ignored — never commit the real one)
# 2. Fill in REAL test-mode values below
# 3. Load it into your shell, then run the sandbox tier:
#
#        set -a; source .env; set +a
#        dotnet test --filter "Category=Sandbox"
#
# Naming: these use the .NET double-underscore convention. `Stripe__SecretKey`
# resolves to the config key `Stripe:SecretKey` — the exact same key as the
# nested JSON { "Stripe": { "SecretKey": ... } } AND the same variable names the
# GitHub `integration-sandbox` CI job sets. One scheme, identical local and CI.
#
# Requirements:
#   • Docker must be running (the test database starts via Testcontainers).
#   • Any provider left blank is SKIPPED (never failed) — fill only what you test.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ──────────────────────────────────────────────────────────────────
# Test mode only. The harness hard-fails (won't run) if this isn't sk_test_/rk_test_.
Stripe__SecretKey=sk_test_REPLACE_ME
Stripe__WebhookSigningSecret=whsec_REPLACE_ME

# ── SendGrid ────────────────────────────────────────────────────────────────
# Sandbox mode is forced ON by the harness, so NO email is ever delivered.
# A real SendGrid key starts with "SG." — it is NOT a Twilio key (SK...).
SendGrid__ApiKey=SG.REPLACE_ME
# Must be a VERIFIED sender in your SendGrid account, or the send is rejected.
SendGrid__FromEmail=verified-sender@yourdomain.com

# ── Twilio ──────────────────────────────────────────────────────────────────
# Use TEST credentials: Console → Account → API keys & tokens → "Test credentials".
# Auth is basic (test Account SID + test Auth Token). Do NOT use an API Key
# (SK.../ApiKeySecret) here — magic test numbers (+15005550006 success,
# +15005550001 failure) only work with test credentials.
Twilio__AccountSid=AC_REPLACE_ME_TEST_SID
Twilio__AuthToken=REPLACE_ME_TEST_AUTH_TOKEN
# Explicit acknowledgement that these are test credentials (the guard requires it):
TWILIO_TEST_CREDENTIALS=true

# ── Optional (harness defaults are already correct for sandbox; leave unset) ──
# SendGrid__Sandbox=true          # forced true by the harness regardless
# Twilio__FromNumber=+15005550006 # magic success "from", defaulted by the harness
