{
  "name": "neko-hoa",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-build-id.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/generate-build-id.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI",
    "e2e": "playwright test",
    "cypress:run": "cypress run --e2e",
    "e2e:ci": "start-server-and-test \"ng serve --configuration development --port 4200\" http-get://localhost:4200 cypress:run",
    "e2e:dev": "cypress run --e2e",
    "e2e:playwright-smoke": "playwright test --grep @smoke",
    "e2e:playwright-dev": "playwright test --grep-invert @local-only",
    "storybook": "ng run neko-hoa:storybook",
    "build-storybook": "ng run neko-hoa:build-storybook"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@opentelemetry/context-zone": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/instrumentation-document-load": "^0.63.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@stripe/stripe-js": "^3.5.0",
    "ngx-stripe": "^21.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.11",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^17.3.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/angular": "^10.4.6",
    "@storybook/blocks": "^8.6.14",
    "@testing-library/angular": "^17.4.0",
    "@testing-library/dom": "^10.4.1",
    "@types/jasmine": "~5.1.0",
    "cypress": "^15.18.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "start-server-and-test": "^2.1.5",
    "storybook": "^8.6.18",
    "typescript": "~5.4.2"
  }
}
